# Supabase (shared with Supabase CLI; service role key is used by the backend
# only to validate the caller's JWT — every DB query is performed with the
# user's access token so RLS still applies).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: id of a vector store the Responses API should expose via file_search.
# Leave blank to disable retrieval (falls back to a plain Responses call).
OPENAI_VECTOR_STORE_ID=

# Chat routing (US-011). 'responses' uses OpenAI's managed Responses API with
# file_search (Module 1). 'completions' uses the stateless Chat Completions API
# with our search_documents tool (Module 2). Per-request `mode` overrides this;
# UI seeds its toggle from /api/config.
CHAT_MODE_DEFAULT=responses

# US-012: sliding window applied to prior messages when rebuilding Chat
# Completions context. A "turn" = one user message + everything that followed
# it (assistant replies, tool calls, tool results) until the next user message.
# Raise to retain more history; lower to trim token cost.
CHAT_HISTORY_MAX_TURNS=20

# CORS: comma-separated list of origins allowed to call the backend.
FRONTEND_ORIGIN=http://localhost:5173

# Chunking pipeline (US-008). Token sizes are cl100k_base; override to tune
# retrieval granularity.
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# Embeddings (US-009). text-embedding-3-small -> 1536 dims (matches the
# vector column in 20260417140000_add_chunks_embedding.sql). Switching to
# text-embedding-3-large (3072 dims) requires altering the column and
# rebuilding the HNSW index.
EMBEDDING_MODEL=text-embedding-3-small
# API-call batch size. Capped at 100 per the PRD; lower values reduce blast
# radius of a transient failure.
EMBEDDING_BATCH_SIZE=100
# Exponential backoff: retries each failing batch this many times before
# failing the ingestion.
EMBEDDING_MAX_RETRIES=3

# Retrieval (US-010). Cosine-similarity floor applied by match_chunks; chunks
# below this score never reach the agent. Must be in [0, 1].
SEARCH_SIMILARITY_THRESHOLD=0.3

# LangSmith observability. Leave LANGSMITH_API_KEY blank to disable tracing.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-rag
# Set to false to keep the SDK installed but silent.
LANGSMITH_TRACING=true
