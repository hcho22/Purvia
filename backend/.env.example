# Supabase (shared with Supabase CLI; service role key is used by the backend
# only to validate the caller's JWT — every DB query is performed with the
# user's access token so RLS still applies).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# US-068 (ADR-0008): the project JWT secret GoTrue signs with. The support bot
# self-signs its short-lived (~60s) bot token with this so auth.uid()/RLS resolve
# it natively (backend/supabase_jwt.py). OPTIONAL: required only when the support
# bot is enabled - a knowledge-assistant-only deploy leaves it blank. NEW signing
# surface: whoever holds it can forge any identity, so keep it server-side only
# and never embed it client-side.
SUPABASE_JWT_SECRET=
# US-069 (ADR-0008): internal, non-routable email domain for the per-workspace
# support bot's auth.users row (backend/support_bot.py). OPTIONAL: defaults to
# bots.support.internal. The bot row is admin-created with email_confirm=true and
# no password, so the address never logs in or receives mail.
SUPPORT_BOT_EMAIL_DOMAIN=bots.support.internal

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: id of a vector store the Responses API should expose via file_search.
# Leave blank to disable retrieval (falls back to a plain Responses call).
OPENAI_VECTOR_STORE_ID=

# --- Model surface: bring your own OpenAI-compatible host (Phase 2) ---
# Provider binds per ROLE (answerer / embedder / judge); model binds per
# CALL-SITE. Two targets are tested: `openai` (default) and `azure`. The
# embedder/judge inherit the answerer config unless overridden, so a
# single-provider deploy leaves all of these blank. Full reference, role
# fallback precedence, worked Azure example, and the embedder re-index
# procedure: docs/model-surface.md
#
# Answerer provider: `openai` (default) or `azure`. A typo fails closed.
LLM_PROVIDER=openai
# Point `openai` at any OpenAI-compatible endpoint (vLLM, Together, Groq,
# Ollama, LM Studio, …). Supported-but-untested. Blank = OpenAI proper.
OPENAI_BASE_URL=
# Azure OpenAI (only when LLM_PROVIDER=azure). All three are required and
# fail closed at startup if any is missing — no api-version default, no
# OPENAI_API_KEY fallback. AZURE_OPENAI_DEPLOYMENT is the deployment NAME
# (NOT the model id); blank => the per-call model id is used as the deployment.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
# Per-role overrides. Each field falls back to the answerer config above. A
# role that sets its own *_BASE_URL points at a distinct host and MUST supply
# its own *_API_KEY (the answerer key is never forwarded to another host). The
# Azure deployment is per-role and never inherited (a chat deployment can't embed).
EMBEDDER_PROVIDER=
EMBEDDER_API_KEY=
EMBEDDER_BASE_URL=
EMBEDDER_AZURE_OPENAI_ENDPOINT=
EMBEDDER_AZURE_OPENAI_API_VERSION=
EMBEDDER_AZURE_OPENAI_DEPLOYMENT=
JUDGE_PROVIDER=
JUDGE_API_KEY=
JUDGE_BASE_URL=
JUDGE_AZURE_OPENAI_ENDPOINT=
JUDGE_AZURE_OPENAI_API_VERSION=
JUDGE_AZURE_OPENAI_DEPLOYMENT=
# Per-call-site model selectors within the answerer provider; each falls back
# to OPENAI_MODEL. (OPENAI_SQL_MODEL and OPENAI_SUBAGENT_MODEL live with their
# tool blocks below; EMBEDDER_MODEL lives with the embeddings block.)
METADATA_MODEL=
OPENAI_PLANNER_MODEL=
OPENAI_RERANK_MODEL=

# Chat routing (US-011). 'responses' uses OpenAI's managed Responses API with
# file_search (Module 1). 'completions' uses the stateless Chat Completions API
# with our search_documents tool (Module 2). Per-request `mode` overrides this;
# UI seeds its toggle from /api/config.
#
# Phase 2: 'responses' runs on OpenAI proper ONLY (LLM_PROVIDER=openai with no
# OPENAI_BASE_URL) — it fails closed at startup on any other answerer. Leave
# blank to default to 'responses' on OpenAI proper and 'completions' elsewhere.
# See docs/model-surface.md.
CHAT_MODE_DEFAULT=responses

# US-012: sliding window applied to prior messages when rebuilding Chat
# Completions context. A "turn" = one user message + everything that followed
# it (assistant replies, tool calls, tool results) until the next user message.
# Raise to retain more history; lower to trim token cost.
CHAT_HISTORY_MAX_TURNS=20

# CORS: comma-separated list of origins allowed to call the backend.
FRONTEND_ORIGIN=http://localhost:5173

# Ingestion parser (US-039, ADR-0007). Selects the DocumentParser that converts
# an uploaded file to Markdown before chunking. `docling` (default) parses
# text-based PDF / DOCX / HTML / MD locally; `llamaparse` is the commercial
# OCR / complex-layout escape hatch; `unstructured` is a reserved
# bring-your-own-adapter slot with no built-in impl. An unknown value fails
# closed at startup — never a silent fallback to docling. To add your own
# parser, see docs/ingestion-parser-adapters.md.
PARSER=docling
# Required only when PARSER=llamaparse: the LlamaCloud API key. Checked at
# startup (not first ingest), so a missing key fails closed at boot.
LLAMA_CLOUD_API_KEY=

# Chunking pipeline (US-008). Token sizes are cl100k_base; override to tune
# retrieval granularity.
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# Embeddings (US-009). text-embedding-3-small -> 1536 dims (matches the
# vector column in 20260417140000_add_chunks_embedding.sql). Switching to
# text-embedding-3-large (3072 dims) requires altering the column and
# rebuilding the HNSW index.
#
# Phase 2: EMBEDDER_MODEL (model-surface, embedder-role-scoped) takes
# precedence over EMBEDDING_MODEL when set; EMBEDDING_MODEL stays as a
# back-compat fallback. The startup guard refuses to boot if the embedder
# drifts from the model the corpus was indexed under — see the re-index
# procedure in docs/model-surface.md.
EMBEDDER_MODEL=
EMBEDDING_MODEL=text-embedding-3-small
# API-call batch size. Capped at 100 per the PRD; lower values reduce blast
# radius of a transient failure.
EMBEDDING_BATCH_SIZE=100
# Exponential backoff: retries each failing batch this many times before
# failing the ingestion.
EMBEDDING_MAX_RETRIES=3

# Retrieval (US-010). Cosine-similarity floor applied by match_chunks; chunks
# below this score never reach the agent. Must be in [0, 1].
SEARCH_SIMILARITY_THRESHOLD=0.3

# LangSmith observability. Leave LANGSMITH_API_KEY blank to disable tracing.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-rag
# Set to false to keep the SDK installed but silent.
LANGSMITH_TRACING=true

# US-023: text-to-SQL tool. Leave ANALYTICS_DATABASE_URL blank to disable —
# the agent simply won't see the `query_database` tool. When set, must
# authenticate as a read-only role (see migration
# 20260506120000_init_analytics_schema.sql which creates `analytics_readonly`
# locally; production deploys should set a strong password manually). Format:
#   postgres://analytics_readonly:<password>@<host>:5432/<db>
ANALYTICS_DATABASE_URL=
# Comma-separated allowlist of schemas the tool may query. Generated SQL
# referencing any other schema is rejected before execution.
ALLOWED_SQL_SCHEMAS=analytics
# Hard statement timeout (per PRD: default 10s).
SQL_QUERY_TIMEOUT_MS=10000
# Optional override for the SQL-generation model. Falls through to OPENAI_MODEL.
OPENAI_SQL_MODEL=

# US-024: web search fallback tool. `none` (default) hides the tool from the
# agent. Switch to `tavily`, `brave`, or `serpapi` and supply the matching
# API key below. The agent is instructed to prefer `search_documents` first
# and only call `web_search` when local retrieval returns nothing relevant.
WEB_SEARCH_PROVIDER=none
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
# Provider HTTP timeout. Web searches that hang past this fall back to
# general knowledge rather than blocking the user's whole turn.
WEB_SEARCH_TIMEOUT_S=10

# US-026 / US-027: full-document sub-agent.
# Heuristic threshold for the system-prompt nudge. Score is 1.0 when the user
# message contains any "summarize / outline / overview" keyword and 0.0
# otherwise; default 0.5 means "any keyword match triggers the hint". Set to
# 1.0 to disable the heuristic (tool description still routes the agent).
FULL_DOCUMENT_INTENT_THRESHOLD=0.5
# Cap on the sub-agent's tool-call loop. Each iteration is a chat.completions
# round-trip; raise for very long documents that need more reads before the
# sub-agent can finalize.
SUBAGENT_MAX_ITERATIONS=12
# Optional: pin a different model just for sub-agent runs (e.g. a longer
# context model). Falls through to OPENAI_MODEL when blank.
OPENAI_SUBAGENT_MODEL=
